{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Token Heatmap",
  "version": "0.1.0",
  "identifier": "com.venuiti.token-heatmap",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Token Heatmap",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Offline viewer for LLM next-token traces",
    "longDescription": "Token Heatmap is an offline viewer for traces produced by the token-heatmap CLI: token probabilities, attention, logit lens, activations, manifold geometry, and attribution graphs. Open a trace file — no server required.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
