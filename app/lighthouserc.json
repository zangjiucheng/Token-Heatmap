{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost/"],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": "off",
        "categories:pwa": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
