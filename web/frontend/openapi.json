  "info": {
    "description": "Converts the library's long-format CSV into the canonical JSON trace payload and exposes the trace JSON Schema.",
    "title": "LLM Token Heatmap API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Return a static OK payload so orchestrators can verify the process is alive.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "health"
        ]
      }
    },
    "/schema": {
      "get": {
        "description": "Return ``docs/web/trace.schema.json`` byte-for-byte.\n\nUses ``application/schema+json`` as the content type so caches and the\nfrontend can distinguish a schema document from a plain JSON payload.",
        "operationId": "get_schema_schema_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Schema",
        "tags": [
          "schema"
        ]
      }
    },
    "/schema/activation": {
      "get": {
        "description": "Return ``docs/web/activation.schema.json`` byte-for-byte.",
        "operationId": "get_activation_schema_schema_activation_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Activation Schema",
        "tags": [
          "schema"
        ]
      }
    },
    "/schema/activation-diff": {
      "get": {
        "description": "Return ``docs/web/activation-diff.schema.json`` byte-for-byte.",
        "operationId": "get_activation_diff_schema_schema_activation_diff_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Activation Diff Schema",
        "tags": [
          "schema"
        ]
      }
    },
    "/schema/activation-sidecar": {
      "get": {
        "description": "Return ``docs/web/activation-sidecar.schema.json`` byte-for-byte.",
        "operationId": "get_activation_sidecar_schema_schema_activation_sidecar_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Activation Sidecar Schema",
        "tags": [
          "schema"
        ]
      }
    },
    "/trace/convert-csv": {
      "post": {
        "description": "Accept the CSV emitted by ``trace_to_dataframe`` and return JSON.",
        "operationId": "convert_csv_trace_convert_csv_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_convert_csv_trace_convert_csv_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Convert Csv",
        "tags": [
          "trace"
        ]
      }
