# Copy this file to .env.local and edit as needed (.env.local is gitignored).
#
# The viewer is backend-free — it loads traces from a dropped file, a
# ?trace=<url> URL, or the bundled sample. There is no API base URL to set.

# Local dev-server port; Vite will pick the next free port if taken.
VITE_DEV_PORT=5173
