# Copy this file to .env.local and edit as needed.
# .env.local is gitignored — safe to put your own values here.
#
# URL of the FastAPI backend.  Change the port if you're running the backend
# on a non-default port or accessing it through an SSH tunnel on a different
# port.  Leave blank ("") when the frontend is served by the backend itself
# (same-origin mode — see docs/web-app.md#hpc--no-npm).
VITE_API_BASE_URL=http://localhost:8000
