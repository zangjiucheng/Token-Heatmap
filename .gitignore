# Virtual environments
venv/
.venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Build
# Anchored to the repo root so it only ignores the Python packaging artifact
# (`/build/`), not source dirs that happen to be named `build`.
/build/
dist/
site/
*.egg-info/

# The user's *global* gitignore ignores `build/` everywhere; re-include the
# frontend's node-editor source feature, which is a real source dir.
!web/frontend/src/features/build/
!web/frontend/src/features/build/**

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.playwright-cli/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment
.env
.env.local
*.env

# Project outputs (keep directory, ignore generated artifacts)
outputs/*
!outputs/.gitkeep

# Workspace
vai-work/
.claude/

# Frontend source assets should be tracked even when a global gitignore has `lib/`.
!web/frontend/src/lib/
!web/frontend/src/lib/**
